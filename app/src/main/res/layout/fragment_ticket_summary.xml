<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Header -->
        <TextView
            android:text="Booking Details"
            android:textColor="#FFFFFF"
            android:textSize="28sp"
            android:textStyle="bold"
            android:layout_marginBottom="24dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <!-- Movie Name -->
        <TextView
            android:id="@+id/tvMovieName"
            android:text="Oppenheimer"
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <!-- Movie Details -->
        <TextView
            android:id="@+id/tvMovieDetails"
            android:text="ScreenX • Dolby Atmos"
            android:textColor="#CCCCCC"
            android:textSize="16sp"
            android:layout_marginBottom="16dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <!-- Theater Section -->
        <TextView
            android:text="Theater"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <TextView
            android:id="@+id/tvTheater"
            android:text="Stars (90°Mall)"
            android:textColor="#CCCCCC"
            android:textSize="16sp"
            android:layout_marginBottom="12dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <!-- Hall and Date -->
        <TextView
            android:id="@+id/tvHallDate"
            android:text="Hall: 1st    Date: 13.04.2025"
            android:textColor="#CCCCCC"
            android:textSize="16sp"
            android:layout_marginBottom="8dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <!-- Time -->
        <TextView
            android:id="@+id/tvTime"
            android:text="Time: 22:15"
            android:textColor="#CCCCCC"
            android:textSize="16sp"
            android:layout_marginBottom="24dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <!-- Tickets Section -->
        <TextView
            android:text="Tickets"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <TextView
            android:id="@+id/tvTickets"
            android:text="• Row E, Seat 5: **$16.00**\n• Row E, Seat 6: **$16.00**\n• Row E, Seat 7: **$16.00**"
            android:textColor="#CCCCCC"
            android:textSize="16sp"
            android:layout_marginBottom="16dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <!-- Snacks Section -->
        <TextView
            android:text="Snacks"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <TextView
            android:id="@+id/tvSnacks"
            android:text="• X2 Medium Salt Popcorn: **$16.00**\n• X1 Large Caramel Popcorn: **$16.00**"
            android:textColor="#CCCCCC"
            android:textSize="16sp"
            android:layout_marginBottom="16dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#333333"
            android:layout_marginVertical="16dp"/>

        <!-- Total -->
        <TextView
            android:id="@+id/tvTotal"
            android:text="TOTAL: $59.98"
            android:textColor="#00FF6A"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="40dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <Button
            android:id="@+id/btnSendTicket"
            android:text="Send Ticket"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:backgroundTint="#E53935"
            android:layout_width="match_parent"
            android:layout_height="60dp"/>

    </LinearLayout>
</ScrollView>